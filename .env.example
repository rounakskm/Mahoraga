# Required for LiteLLM gateway (Task 7)
ANTHROPIC_API_KEY=sk-ant-...
# NVIDIA Build (NIM) hosted inference — free tier. Generate at https://build.nvidia.com
# (open any model, e.g. nemotron-3-ultra-550b-a55b, → "Get API Key"). Starts with nvapi-.
# Powers the Hermes orchestrator via LiteLLM (nvidia/nemotron-ultra | nvidia/nemotron-super).
NVIDIA_API_KEY=nvapi-...
# Optional for additional providers
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# Postgres (Task 2 + Task 8)
POSTGRES_PASSWORD=change_me_locally

# Ollama on host (Task 12)
OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_HOST=http://ollama:11434             # use when running Docker-Ollama override

# Local model — switch by commenting/uncommenting (default: 26b primary)
OLLAMA_MODEL=gemma4:26b
# OLLAMA_MODEL=gemma4:e4b              # fallback if 26b is too slow on this hardware

# Phase 0 / Phase 6 additions for the consolidated-assistant model
LITELLM_BASE_URL=http://litellm:4000/v1
MAIN_MODEL=nvidia/nemotron-ultra            # Hermes orchestrator model (LiteLLM alias); falls back to ollama/gemma4
TELEGRAM_BOT_TOKEN=                         # operator creates bot via @BotFather, pastes token here
TELEGRAM_CHAT_ID=                           # the operator's chat ID (numeric); allowlist for /halt etc.

# Hindsight memory layer (vendor/hindsight/, see 2026-05-03-hindsight-memory-layer-revision.md)
HINDSIGHT_DB_PASSWORD=change_me_locally     # password for the hindsight-db Postgres (separate from main postgres)

# Phase 1 data foundation
# yfinance is unauthenticated; no key needed.
# FRED requires an API key (free, instant): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=                              # required by services/trader/data/connectors/fred.py
BLS_API_KEY=                               # optional: cross-check for FRED CPI/NFP; https://www.bls.gov/developers/

# Phase 4/5 — Alpaca (paper trading + news archive). Free account: https://alpaca.markets
# News archive covers ~2020-present; pre-2020 uses price-action proxies (see phase-4 plan).
ALPACA_API_KEY=                            # required by services/trader/news/alpaca_news.py + Phase-5 broker
ALPACA_SECRET_KEY=                         # paired secret
ALPACA_PAPER_ENDPOINT=https://paper-api.alpaca.markets/v2   # paper trading (no real capital)
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets           # market data + news REST/websocket

# Phase-5/6 operations
MAHORAGA_DSN=                              # postgresql://postgres:<POSTGRES_PASSWORD>@localhost:5432/postgres — trade store, provenance, audit
MAHORAGA_PAPER_STRATEGY=                   # strategies/<run>.json artifact the daily paper cadence trades (default: latest seed4)
MAHORAGA_HINDSIGHT_URL=                    # http://localhost:8888 when the Hindsight memory sidecar is up (optional)
