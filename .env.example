# Required for LiteLLM gateway (Task 7)
ANTHROPIC_API_KEY=sk-ant-...
# Optional for additional providers
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# Postgres (Task 2 + Task 8)
POSTGRES_PASSWORD=change_me_locally

# Ollama on host (Task 12)
OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_HOST=http://ollama:11434             # use when running Docker-Ollama override

# Local model — switch by commenting/uncommenting (default: 26b primary)
OLLAMA_MODEL=gemma4:26b
# OLLAMA_MODEL=gemma4:e4b              # fallback if 26b is too slow on this hardware

# Phase 0 / Phase 6 additions for the consolidated-assistant model
LITELLM_BASE_URL=http://litellm:4000/v1
MAIN_MODEL=anthropic/claude-opus-4-7        # Main orchestrator's preferred model; falls back to ollama/gemma4
TELEGRAM_BOT_TOKEN=                         # operator creates bot via @BotFather, pastes token here
TELEGRAM_CHAT_ID=                           # the operator's chat ID (numeric); allowlist for /halt etc.

# Hindsight memory layer (vendor/hindsight/, see 2026-05-03-hindsight-memory-layer-revision.md)
HINDSIGHT_DB_PASSWORD=change_me_locally     # password for the hindsight-db Postgres (separate from main postgres)
