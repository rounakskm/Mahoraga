# Inputs for `nemoclaw onboard --agent hermes --non-interactive` (NemoClaw v0.1.0).
# Source from .env at onboarding time, then run scripts/onboard.sh.
# Harness migrated OpenClaw -> Hermes 2026-06-12 (ADR 2026-06-12-hermes-runtime-migration.md).
#
# These are the REAL env vars NemoClaw v0.1.0 reads (verified live during the
# 2026-06-12 Rung-C bring-up). The earlier NEMOCLAW_BLUEPRINT_PATH /
# NEMOCLAW_INFERENCE_* names were wrong — v0.1.0 onboarding is wizard-driven,
# configured by the variables below, not by a single blueprint file.
# blueprint.yaml is now design-intent documentation, not a consumed artifact.

NEMOCLAW_AGENT=hermes
NEMOCLAW_NON_INTERACTIVE=1
NEMOCLAW_ACCEPT_THIRD_PARTY_SOFTWARE=1
NEMOCLAW_SANDBOX_NAME=mahoraga-hermes

# Inference: route Hermes through our LiteLLM gateway (provider "custom" ==
# compatible-endpoint). localhost:4000 is correct for ONBOARDING (NemoClaw
# validates the endpoint host-side, where localhost:4000 reaches LiteLLM).
# At RUNTIME the OpenShell gateway forwards from inside its own bridge-network
# container, where localhost:4000 is unreachable -> scripts/onboard.sh repoints
# the provider to http://host.docker.internal:4000 after onboarding. See the
# "localhost vs host.docker.internal" note in scripts/onboard.sh.
NEMOCLAW_PROVIDER=custom
NEMOCLAW_ENDPOINT_URL=http://localhost:4000           # LiteLLM; NemoClaw appends /v1/chat/completions
NEMOCLAW_MODEL=nvidia/nemotron-ultra                  # LiteLLM alias -> nvidia/nemotron-3-ultra-550b-a55b
COMPATIBLE_API_KEY=${LITELLM_MASTER_KEY}              # auth for the LiteLLM gateway

# Telegram bot — operator creates via @BotFather, pastes token in .env. Added
# post-onboard with: nemoclaw mahoraga-hermes channels add telegram
# NEMOCLAW_TELEGRAM_TOKEN handled via `channels add`, not onboarding env.
